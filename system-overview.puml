@startuml 系统功能全图

!define RECTANGLE class

skinparam rectangle {
    BackgroundColor<<system>> LightBlue
    BackgroundColor<<module>> LightGreen
    BackgroundColor<<external>> LightYellow
    BorderColor Black
    FontSize 12
}

skinparam arrow {
    Color Black
    FontSize 10
}

title 系统功能架构全图

' 外部系统和用户
actor "普通用户" as User
actor "管理员" as Admin
actor "业务人员" as Business

rectangle "外部系统" <<external>> {
    rectangle "第三方登录\n(OAuth)" as OAuth
    rectangle "短信服务" as SMS
    rectangle "邮件服务" as Email
    rectangle "对象存储" as OSS
}

' 主系统
rectangle "应用系统" <<system>> {

    ' 前端层
    rectangle "前端展示层" <<module>> {
        rectangle "用户界面" as UI {
            rectangle "登录页面" as LoginPage
            rectangle "注册页面" as RegisterPage
            rectangle "用户中心" as UserCenter
            rectangle "业务管理页面" as BusinessPage
            rectangle "系统管理页面" as AdminPage
        }

        rectangle "前端组件库" as Components {
            rectangle "通用组件" as CommonComp
            rectangle "业务组件" as BusinessComp
            rectangle "布局组件" as LayoutComp
        }
    }

    ' API 网关层
    rectangle "API 网关层" <<module>> {
        rectangle "路由管理" as Router
        rectangle "负载均衡" as LoadBalancer
        rectangle "API 限流" as RateLimit
        rectangle "请求日志" as RequestLog
    }

    ' 业务服务层
    rectangle "业务服务层" <<module>> {

        rectangle "用户管理模块" as UserModule {
            rectangle "用户注册" as Register
            rectangle "用户登录" as Login
            rectangle "用户信息管理" as UserInfo
            rectangle "密码管理" as Password
        }

        rectangle "权限管理模块" as PermModule {
            rectangle "角色管理" as RoleManage
            rectangle "权限分配" as PermAssign
            rectangle "权限验证" as PermCheck
            rectangle "访问控制" as AccessControl
        }

        rectangle "业务功能模块" as BizModule {
            rectangle "数据录入" as DataEntry
            rectangle "数据查询" as DataQuery
            rectangle "数据分析" as DataAnalysis
            rectangle "数据导入导出" as DataIO
        }

        rectangle "系统管理模块" as SysModule {
            rectangle "日志管理" as LogManage
            rectangle "系统配置" as SysConfig
            rectangle "监控告警" as Monitor
            rectangle "备份恢复" as Backup
        }
    }

    ' 中间件层
    rectangle "中间件层" <<module>> {
        rectangle "认证中间件" as AuthMiddleware
        rectangle "权限中间件" as PermMiddleware
        rectangle "验证中间件" as ValidMiddleware
        rectangle "错误处理中间件" as ErrorMiddleware
        rectangle "日志中间件" as LogMiddleware
    }

    ' 数据访问层
    rectangle "数据访问层" <<module>> {
        rectangle "用户数据访问" as UserDAO
        rectangle "角色数据访问" as RoleDAO
        rectangle "业务数据访问" as BusinessDAO
        rectangle "日志数据访问" as LogDAO
        rectangle "缓存管理" as Cache
    }

    ' 基础设施层
    rectangle "基础设施层" <<module>> {
        rectangle "工具类库" as Utils {
            rectangle "JWT 工具" as JWT
            rectangle "加密工具" as Crypto
            rectangle "验证工具" as Validator
            rectangle "日期工具" as DateUtil
        }

        rectangle "配置管理" as Config {
            rectangle "数据库配置" as DBConfig
            rectangle "认证配置" as AuthConfig
            rectangle "应用配置" as AppConfig
        }
    }
}

' 数据存储层
rectangle "数据存储层" <<external>> {
    database "关系数据库\n(MySQL/PostgreSQL)" as DB
    database "缓存数据库\n(Redis)" as Redis
    database "文档存储\n(MongoDB)" as MongoDB
    storage "文件存储" as FileStorage
}

' 用户与前端的关系
User --> LoginPage : 访问
User --> RegisterPage : 注册
User --> UserCenter : 管理个人信息
User --> BusinessPage : 使用业务功能

Admin --> AdminPage : 系统管理
Admin --> UserCenter : 管理个人信息

Business --> BusinessPage : 业务操作
Business --> UserCenter : 管理个人信息

' 前端与组件的关系
LoginPage ..> CommonComp : 使用
RegisterPage ..> CommonComp : 使用
UserCenter ..> CommonComp : 使用
BusinessPage ..> BusinessComp : 使用
AdminPage ..> CommonComp : 使用

UI ..> LayoutComp : 使用布局

' 前端与 API 网关的关系
UI --> Router : HTTP 请求

' API 网关内部关系
Router --> LoadBalancer : 分发请求
LoadBalancer --> RateLimit : 限流检查
RateLimit --> RequestLog : 记录日志

' API 网关与中间件的关系
RequestLog --> AuthMiddleware : 认证
AuthMiddleware --> PermMiddleware : 授权
PermMiddleware --> ValidMiddleware : 验证
ValidMiddleware --> ErrorMiddleware : 错误处理
ValidMiddleware --> LogMiddleware : 日志记录

' 中间件与业务服务的关系
LogMiddleware --> UserModule : 调用
LogMiddleware --> PermModule : 调用
LogMiddleware --> BizModule : 调用
LogMiddleware --> SysModule : 调用

' 用户模块内部关系
Register ..> Login : 注册后登录
Login ..> UserInfo : 登录后访问
UserInfo ..> Password : 修改密码

' 业务服务与数据访问的关系
UserModule --> UserDAO : 数据操作
PermModule --> RoleDAO : 数据操作
BizModule --> BusinessDAO : 数据操作
SysModule --> LogDAO : 数据操作

' 数据访问与缓存的关系
UserDAO --> Cache : 缓存用户信息
RoleDAO --> Cache : 缓存权限信息
BusinessDAO --> Cache : 缓存业务数据

' 数据访问与数据库的关系
UserDAO --> DB : 持久化
RoleDAO --> DB : 持久化
BusinessDAO --> DB : 持久化
BusinessDAO --> MongoDB : 文档存储
LogDAO --> DB : 持久化

Cache --> Redis : 缓存存储

' 业务服务与工具类的关系
UserModule ..> JWT : Token 生成
UserModule ..> Crypto : 密码加密
UserModule ..> Validator : 数据验证
BizModule ..> DateUtil : 日期处理

' 业务服务与配置的关系
UserModule ..> AuthConfig : 读取配置
BizModule ..> AppConfig : 读取配置
UserDAO ..> DBConfig : 数据库连接

' 业务服务与外部系统的关系
Login --> OAuth : 第三方登录
Register --> SMS : 发送验证码
Register --> Email : 发送邮件
UserInfo --> OSS : 上传头像
DataIO --> FileStorage : 文件存储

' 系统管理模块关系
Monitor --> LogManage : 监控日志
Monitor --> SysConfig : 读取配置
Backup --> DB : 备份数据
Backup --> FileStorage : 备份文件

' 权限验证流程
PermCheck --> AccessControl : 访问控制
AccessControl --> PermMiddleware : 权限拦截

' 注释说明
note right of User
  普通用户可以：
  - 注册和登录
  - 管理个人信息
  - 使用基本业务功能
end note

note right of Admin
  管理员可以：
  - 管理用户和角色
  - 配置系统参数
  - 查看系统日志
  - 监控系统状态
end note

note right of Business
  业务人员可以：
  - 录入业务数据
  - 查询和分析数据
  - 导入导出数据
end note

note bottom of "业务服务层"
  业务服务层采用模块化设计
  各模块职责清晰，低耦合高内聚
  支持独立部署和扩展
end note

note bottom of "数据访问层"
  数据访问层统一管理数据操作
  支持缓存策略提升性能
  提供事务管理保证数据一致性
end note

@enduml
