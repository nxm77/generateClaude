  "business_flows": [
    {
      "name": "用户注册流程",
      "trigger": "POST /api/auth/register",
      "steps": [
        {
          "step": 1,
          "action": "接收注册请求",
          "component": "authController.register",
          "description": "接收用户提交的注册信息"
        },
        {
          "step": 2,
          "action": "验证输入数据",
          "component": "validateUserInput middleware",
          "validations": [
            "用户名格式：3-50字符，字母数字",
            "邮箱格式：有效的邮箱地址",
            "密码强度：至少8字符，包含大小写字母和数字"
          ],
          "on_error": "返回 400 错误和详细验证信息"
        },
        {
          "step": 3,
          "action": "检查用户名和邮箱唯一性",
          "component": "checkDuplicateEmail middleware",
          "database_query": "SELECT * FROM users WHERE email = ? OR username = ?",
          "on_duplicate": "返回 409 错误：用户已存在"
        },
        {
          "step": 4,
          "action": "加密密码",
          "component": "authService.hashPassword",
          "method": "bcrypt",
          "salt_rounds": 10,
          "description": "使用 bcrypt 加密用户密码"
        },
        {
          "step": 5,
          "action": "创建用户记录",
          "component": "User.create",
          "transaction": true,
          "database_operation": "INSERT INTO users",
          "on_error": "回滚事务，返回 500 错误"
        },
        {
          "step": 6,
          "action": "生成 JWT Token",
          "component": "authService.generateToken",
          "payload": {
            "userId": "number",
            "email": "string"
          },
          "expiry": "24h",
          "secret": "process.env.JWT_SECRET"
        },
        {
          "step": 7,
          "action": "发送欢迎邮件",
          "component": "emailService.sendWelcomeEmail",
          "async": true,
          "description": "异步发送欢迎邮件，不阻塞响应",
          "on_error": "记录日志但不影响注册流程"
        },
        {
          "step": 8,
          "action": "返回成功响应",
          "response": {
            "status": 201,
            "body": {
              "id": "用户ID",
              "username": "用户名",
              "email": "邮箱",
              "token": "JWT Token"
            }
          }
        }
      ],
      "error_handling": [
        {
          "error": "ValidationError",
          "status": 400,
          "action": "返回验证错误详情"
        },
        {
          "error": "DuplicateError",
          "status": 409,
          "action": "返回用户已存在错误"
        },
        {
          "error": "DatabaseError",
          "status": 500,
          "action": "回滚事务，记录错误日志"
        }
      ],
      "performance": {
        "average_time": "200ms",
        "database_queries": 2,
        "cache_usage": false
      }
    },
    {
      "name": "用户登录流程",
      "trigger": "POST /api/auth/login",
      "steps": [
        {
          "step": 1,
          "action": "接收登录请求",
          "component": "authController.login"
        },
        {
          "step": 2,
          "action": "验证输入格式",
          "component": "validateLoginInput middleware",
          "validations": ["邮箱格式", "密码非空"]
        },
        {
          "step": 3,
          "action": "查询用户",
          "component": "User.findOne",
          "database_query": "SELECT * FROM users WHERE email = ?",
          "cache_check": true,
          "cache_key": "user:email:{email}",
          "cache_ttl": "5m"
        },
        {
          "step": 4,
          "action": "验证密码",
          "component": "authService.comparePassword",
          "method": "bcrypt.compare",
          "on_mismatch": "返回 401 错误"
        },
        {
          "step": 5,
          "action": "生成 JWT Token",
          "component": "authService.generateToken"
        },
        {
          "step": 6,
          "action": "缓存用户信息",
          "component": "cacheService.set",
          "cache_key": "user:{userId}",
          "cache_ttl": "1h"
        },
        {
          "step": 7,
          "action": "记录登录日志",
          "component": "logService.logLogin",
          "async": true
        },
        {
          "step": 8,
          "action": "返回成功响应",
          "response": {
            "status": 200,
            "body": {
              "token": "JWT Token",
              "user": "用户信息"
            }
          }
        }
      ],
      "error_handling": [
        {
          "error": "UserNotFound",
          "status": 401,
          "action": "返回凭证无效错误（不透露用户是否存在）"
        },
        {
          "error": "PasswordMismatch",
          "status": 401,
          "action": "返回凭证无效错误"
        }
      ],
      "performance": {
        "average_time": "150ms",
        "database_queries": 1,
        "cache_usage": true
      }
    },
    {
      "name": "获取文章列表流程",
      "trigger": "GET /api/posts",
      "steps": [
        {
          "step": 1,
          "action": "接收请求",
          "component": "postController.getPosts"
        },
        {
          "step": 2,
          "action": "验证分页参数",
          "component": "validatePagination middleware",
          "validations": ["page >= 1", "limit between 1-100"]
        },
        {
          "step": 3,
          "action": "检查缓存",
          "component": "cacheService.get",
          "cache_key": "posts:page:{page}:limit:{limit}:author:{author}",
          "on_hit": "直接返回缓存数据"
        },
        {
          "step": 4,
          "action": "查询数据库",
          "component": "Post.findAndCountAll",
          "database_query": "SELECT * FROM posts WHERE published = true ORDER BY createdAt DESC LIMIT ? OFFSET ?",
          "includes": ["User"],
          "pagination": true
        },
        {
          "step": 5,
          "action": "缓存结果",
          "component": "cacheService.set",
          "cache_ttl": "5m"
        },
        {
          "step": 6,
          "action": "返回响应",
          "response": {
            "status": 200,
            "body": {
              "posts": "文章数组",
              "pagination": "分页信息"
            }
          }
        }
      ],
      "performance": {
        "average_time": "50ms (cached) / 200ms (uncached)",
        "database_queries": 1,
        "cache_usage": true
      }
    }
  ],
