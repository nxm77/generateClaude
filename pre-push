#!/bin/bash

# ============================================================
# CX-AICODE CodeReview Push Gate
#
# 安装位置：
#   .git/hooks/pre-push
#
# 检查规则：
#   1. 必须存在最新的 CodeReview-yyyyMMdd-HHmmss.md 报告
#   2. 最新报告内未 bypass 的 [紧急] 或 [严重] marker 必须为 0
#      (已 bypass 的 marker 形式: [紧急-非问题 <原因>] / [严重-暂不修复 <原因>])
#   3. 最新报告的生成时间必须晚于本次 push 涉及文件的最新提交时间
#
# 交互式 bypass(有 TTY 时):
#   - 对每个未 bypass 的 issue 显示完整内容
#   - 三选一: [1] 是问题 / [2] 非问题 / [3] 暂不修复(单键直接选定,无需空格循环)
#   - 选 [2]/[3] 后填写原因(cooked 模式原生回显 + 行编辑,支持中文/退格/IME;[3] 必填,[2] 可空)
#   - 原因行按 Esc+回车 可返回重选;q 取消整个 push
#   - TTY 不可用(CI 等)时退化为硬阻断,不静默放行
#
# 适用范围：
#   - 普通分支 push
#   - 首次 push 新分支（保守检查当前分支全部文件）
#   - 删除远端分支时跳过检查
#   - tag push 暂时跳过检查
#
# 限制：
#   - 基于 git 提交时间判定过期（不依赖工作区 mtime）；当前仍只允许 push 当前已检出的分支
#   - 删除/重命名文件经 git log 同样可取提交时间，一并参与过期比较
#   - 本地 hook 可被 git push --no-verify 绕过
#   - 交互通过 /dev/tty 读用户输入,与 stdin 的 ref 列表协议隔离
# ============================================================

set -u

REPORT_DIR=".cx/reports/codereview"
REPORT_PATTERN="CodeReview-????????-??????.md"

TMP_FILES="$(mktemp)" || exit 1
ISSUES_TMP="$(mktemp)" || exit 1
STALE_FILES_TMP="$(mktemp)" || exit 1
BYPASS_TMP="$(mktemp)" || exit 1

cleanup() {
    rm -f "$TMP_FILES" "$ISSUES_TMP" "$STALE_FILES_TMP" "$BYPASS_TMP"
}

trap cleanup EXIT

print_separator() {
    echo "============================================================" >&2
}

fail() {
    print_separator
    echo "[CX-AICODE] Git push 已阻止" >&2
    echo "$1" >&2
    print_separator
    exit 1
}

# 同时兼容 SHA-1 和 SHA-256 仓库中的全零 object ID。
is_zero_oid() {
    case "${1:-}" in
        ""|*[!0]*) return 1 ;;
        *)          return 0 ;;
    esac
}

# 同时兼容 Git Bash / Linux 和 macOS。
get_mtime_epoch() {
    local file_path="$1"

    if stat -c %Y "$file_path" >/dev/null 2>&1; then
        stat -c %Y "$file_path"
        return 0
    fi

    if stat -f %m "$file_path" >/dev/null 2>&1; then
        stat -f %m "$file_path"
        return 0
    fi

    fail "无法读取文件修改时间：$file_path"
}

# 返回文件在本次推送范围内最新一次提交的 committer 时间（epoch 秒）。
# range：普通 push 传 "$REMOTE_OID..$LOCAL_OID"；首次推送（REMOTE_OID 全零）传 "$LOCAL_OID"。
# 文件在范围内无提交记录（理论上不会发生）时返回空串，由调用方跳过。
# 用提交时间而非工作区 mtime：不受 checkout/stash/rebase 重置 mtime 影响，
# 且对删除/重命名/非 ASCII 文件名文件同样有效（git log 按路径查历史）。
get_file_commit_epoch() {
    local file_path="$1"
    local range="$2"
    [ -n "$range" ] || return 0
    git log --max-count=1 --format=%ct "$range" -- "$file_path" 2>/dev/null || true
}

# 读 .cx/index.json 的 focusedSpec。node 优先，无 node 则 sed 兜底；缺文件返回空。
# 镜像 hooks/bash/lib/common.sh 的 cx_focused_spec；此处内联是为了让 pre-push 作为
# 独立 git hook（可能被复制到 .git/hooks/）不依赖按相对路径 source 共享库。
read_focused_spec() {
    local idx="$REPO_ROOT/.cx/index.json"
    [ -f "$idx" ] || return 0
    if [ -n "${SIDECAR_NODE_BIN:-}" ]; then
        CX_INDEX_FILE="$idx" "$SIDECAR_NODE_BIN" -e '
const fs=require("fs");
try{const d=JSON.parse(fs.readFileSync(process.env.CX_INDEX_FILE,"utf8").replace(/^﻿/,""));
process.stdout.write(d.focusedSpec?String(d.focusedSpec):"");}catch(_){}
' 2>/dev/null || true
    else
        sed -n 's/.*"focusedSpec"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$idx" 2>/dev/null | head -1 || true
    fi
}

find_node_bin() {
    command -v node 2>/dev/null || command -v nodejs 2>/dev/null || echo ""
}

resolve_hook_plugin_root() {
    local hook_dir
    hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)"

    if [ -n "${CX_AICODE_PLUGIN_ROOT:-}" ] && [ -f "$CX_AICODE_PLUGIN_ROOT/scripts/codereview/sidecar-cli.js" ]; then
        printf '%s\n' "$CX_AICODE_PLUGIN_ROOT"
        return 0
    fi
    if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "$CLAUDE_PLUGIN_ROOT/scripts/codereview/sidecar-cli.js" ]; then
        printf '%s\n' "$CLAUDE_PLUGIN_ROOT"
        return 0
    fi
    if [ -n "$hook_dir" ] && [ -f "$hook_dir/scripts/codereview/sidecar-cli.js" ]; then
        printf '%s\n' "$hook_dir"
        return 0
    fi
    if [ -f "$REPO_ROOT/scripts/codereview/sidecar-cli.js" ]; then
        printf '%s\n' "$REPO_ROOT"
        return 0
    fi

    printf '\n'
}

sidecar_path_for_report() {
    local report="$1"
    case "$report" in
        *.md) printf '%s.json\n' "${report%.md}" ;;
        *)    printf '%s.json\n' "$report" ;;
    esac
}

sidecar_available() {
    local report="$1"
    local sidecar_path
    sidecar_path="$(sidecar_path_for_report "$report")"
    [ -n "${SIDECAR_NODE_BIN:-}" ] \
        && [ -n "${SIDECAR_HELPER:-}" ] \
        && [ -f "$SIDECAR_HELPER" ] \
        && [ -f "$sidecar_path" ]
}

extract_blockers_sidecar() {
    local report="$1"
    "$SIDECAR_NODE_BIN" "$SIDECAR_HELPER" blockers \
        --project-root "$REPO_ROOT" \
        --report "$report"
}

extract_issue_block_sidecar() {
    local report="$1"
    local issue_id="$2"
    "$SIDECAR_NODE_BIN" "$SIDECAR_HELPER" issue-block \
        --report "$report" \
        --issue-id "$issue_id"
}

record_bypass_decision() {
    local report="$1"
    local issue_id="$2"
    local severity="$3"
    local kind="$4"
    local reason="$5"
    local response

    sidecar_available "$report" || return 0

    case "$kind" in
        非问题)   response="non-issue" ;;
        暂不修复) response="wont-fix" ;;
        *)        return 1 ;;
    esac

    "$SIDECAR_NODE_BIN" "$SIDECAR_HELPER" record-bypass \
        --project-root "$REPO_ROOT" \
        --report "$report" \
        --issue-id "$issue_id" \
        --severity "$severity" \
        --response "$response" \
        --reason "$reason" \
        --push-id "${UPLOAD_PUSH_ID:-}" \
        --commit "${UPLOAD_COMMIT:-}" \
        --branch "${UPLOAD_BRANCH:-}" \
        >/dev/null
}

get_report_epoch() {
    local report="$1"
    local epoch

    if sidecar_available "$report"; then
        epoch="$("$SIDECAR_NODE_BIN" "$SIDECAR_HELPER" fresh-epoch --report "$report" 2>/dev/null || true)"
        if [ -n "$epoch" ] && printf '%s' "$epoch" | grep -Eq '^[0-9]+$'; then
            printf '%s\n' "$epoch"
            return 0
        fi
    fi

    get_mtime_epoch "$report"
}

# ============================================================
# 交互式 bypass 模块
#
# 流程:每个阻断级 issue 一次:
#   阶段 1: 三选一 — 按 1=是问题 / 2=非问题 / 3=暂不修复(单键直接选定);q 取消整个 push
#   阶段 2: 选 2/3 时填写原因(cooked 模式,终端原生回显 + 行编辑)
#            非问题 原因可空;暂不修复 原因必填(空则重提示)
#            原因行行首为 ESC(0x1B)时回退到阶段 1(重新三选一)
# 所有阻断 issue 都处理完后:无 是问题 残留 → 放行,否则阻断。
# ============================================================

# 真实阻断级 issue 标记行的 grep 正则(精确匹配 issue marker,避免命中表格/JSON)。
BLOCKER_MARKER_RE='\*\*Issue #[0-9]+\*\* \[(紧急|严重)\]'
# 已 bypass 的 marker 正则(允许 -非问题 / -暂不修复 后接原因)。
BYPASSED_MARKER_RE='\*\*Issue #[0-9]+\*\* \[(紧急|严重)-(非问题|暂不修复)(\s|\])'

# Map raw severity label to canonical Chinese label.
# Handles LLM variants (阻塞, Critical, High, etc.)
canonicalize_severity() {
    case "$1" in
        紧急|阻塞|Critical|critical|L1) echo "紧急" ;;
        严重|High|high|L2) echo "严重" ;;
        一般|Medium|medium|L3) echo "一般" ;;
        轻微|Low|low|L4) echo "轻微" ;;
        *) echo "$1" ;;
    esac
}

# Copy src to dst with all variant severity labels mapped to canonical format.
# Used as pre-processing before regex matching.
# Line count is preserved (no lines added/removed), so line numbers are stable.
normalize_report_content() {
    local src="$1"
    local dst="$2"
    sed -E \
        -e 's/【/[/g' \
        -e 's/】/]/g' \
        -e 's/\((紧急|严重|一般|轻微|Critical|critical|High|high|Medium|medium|Low|low|H[1-4]|L[1-4]|阻塞)\)/[\1]/g' \
        -e 's/\(L([1-4]) +(紧急|严重|一般|轻微)\)/[\2]/g' \
        -e 's/\(H([1-4])[: ]+(紧急|严重|一般|轻微|Critical|critical|High|high|Medium|medium|Low|low)\)/[\2]/g' \
        -e 's/\((紧急|严重|一般|轻微|Critical|critical|High|high|Medium|medium|Low|low|H[1-4]|L[1-4]|阻塞)-([^)]+)\)/[\1-\2]/g' \
        -e 's/\[(H[1-4])[: ]+(紧急|严重|一般|轻微|Critical|critical|High|high|Medium|medium|Low|low|L[1-4])\]/[\2]/g' \
        -e 's/\[(Critical|critical|High|high|Medium|medium|Low|low)[: ]+(紧急|严重|一般|轻微|Critical|critical|High|high|Medium|medium|Low|low)\]/[\2]/g' \
        -e 's/\[(级别|优先级|severity|level|Severity|Level|SEVERITY|LEVEL)[: ]+(紧急|严重|一般|轻微|Critical|critical|High|high|Medium|medium|Low|low|L[1-4])\]/[\2]/g' \
        -e 's/\[H1\]/[紧急]/g' -e 's/\[H1-/[紧急-/g' \
        -e 's/\[H2\]/[严重]/g' -e 's/\[H2-/[严重-/g' \
        -e 's/\[H3\]/[一般]/g' -e 's/\[H3-/[一般-/g' \
        -e 's/\[H4\]/[轻微]/g' -e 's/\[H4-/[轻微-/g' \
        -e 's/\[L1\]/[紧急]/g' \
        -e 's/\[L2\]/[严重]/g' \
        -e 's/\[L3\]/[一般]/g' \
        -e 's/\[L4\]/[轻微]/g' \
        -e 's/\[L[1-4] +(紧急|严重|一般|轻微)\]/[\1]/g' \
        -e 's/\[L[1-4] +(紧急|严重|一般|轻微)(-[^]]*)\]/[\1\2]/g' \
        -e 's/\[[0-9]+-(紧急|严重|一般|轻微)\]/[\1]/g' \
        -e 's/\[阻塞\]/[紧急]/g' -e 's/\[阻塞-/[紧急-/g' \
        -e 's/\[Critical\]/[紧急]/g' -e 's/\[critical\]/[紧急]/g' \
        -e 's/\[Critical-/[紧急-/g' -e 's/\[critical-/[紧急-/g' \
        -e 's/\[High\]/[严重]/g' -e 's/\[high\]/[严重]/g' \
        -e 's/\[High-/[严重-/g' -e 's/\[high-/[严重-/g' \
        -e 's/\[Medium\]/[一般]/g' -e 's/\[medium\]/[一般]/g' \
        -e 's/\[Medium-/[一般-/g' -e 's/\[medium-/[一般-/g' \
        -e 's/\[Low\]/[轻微]/g' -e 's/\[low\]/[轻微]/g' \
        -e 's/\[Low-/[轻微-/g' -e 's/\[low-/[轻微-/g' \
        -e 's/\*\*  +\[/** [/g' \
        -e 's/\*\*问题 #([0-9]+)\*\*/**Issue #\1**/g' \
        "$src" > "$dst"
}

# 从报告里提取所有未 bypass 的 issue marker,输出 TSV: <issue_num>\t<severity>\t<line>
extract_blocker_markers() {
    local report="$1"
    local normalized
    normalized=$(mktemp) || return 1
    normalize_report_content "$report" "$normalized"
    LC_ALL=C grep -nE "$BLOCKER_MARKER_RE" "$normalized" \
        | LC_ALL=C grep -vE "$BYPASSED_MARKER_RE" \
        | LC_ALL=C sed -nE 's/^([0-9]+):\*\*Issue #([0-9]+)\*\* \[(紧急|严重)\].*$/\2\t\3\t\1/p'
    local rc=$?
    rm -f "$normalized"
    return $rc
}

# 从报告里提取指定 marker 所在 issue 的完整块(marker 行到下一个 --- 或 **Issue # 或 ## 或 EOF)
extract_issue_block() {
    local report="$1"
    local start_line="$2"
    awk -v start="$start_line" '
        NR < start { next }
        NR == start { print; in_block = 1; next }
        in_block {
            if ($0 ~ /^---$/ || $0 ~ /^\*\*Issue #[0-9]+\*\*/ || $0 ~ /^## /) {
                exit
            }
            print
        }
    ' "$report"
}

# JSON fallback: extract L1/L2 issues from cx-agent-result JSON block in report.
# Outputs same TSV format as extract_blocker_markers: <issue_num>\t<severity>\t<line>
# Matches JSON issues to markdown headings by scanning for **Issue #N** lines.
infer_severity_from_json() {
    local report="$1"
    local bypassed_nums="${2:-}"
    # Normalize the report for heading matching (handles **问题 #N** variants)
    local norm_report
    norm_report=$(mktemp) || return 1
    normalize_report_content "$report" "$norm_report"
    # Extract JSON block content between ```json cx-agent-result and ```
    local json_content
    json_content=$(awk '/^```json cx-agent-result/{found=1; next} found && /^```/{exit} found{print}' "$norm_report")
    if [ -z "$json_content" ]; then
        rm -f "$norm_report"
        return 1
    fi

    # Extract file+line pairs for L1/L2 issues using grep + sed
    # Match lines like: "severity": "L1" or "severity": "L2"
    # Then look for preceding "file": and "line": in the same issue object
    local i=0 issue_num severity file_path line_num
    local -a issue_nums=() issue_sevs=() issue_files=() issue_lines=()
    local current_file="" current_line="" current_sev=""

    while IFS= read -r json_line; do
        # Track current issue fields
        local f l s
        f=$(printf '%s' "$json_line" | sed -nE 's/.*"file"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p')
        l=$(printf '%s' "$json_line" | sed -nE 's/.*"line"[[:space:]]*:[[:space:]]*([0-9]+).*/\1/p')
        s=$(printf '%s' "$json_line" | sed -nE 's/.*"severity"[[:space:]]*:[[:space:]]*"([A-Z][0-9])".*/\1/p')
        [ -n "$f" ] && current_file="$f"
        [ -n "$l" ] && current_line="$l"
        [ -n "$s" ] && current_sev="$s"

        # When we hit a closing brace or comma after an issue, emit if L1/L2
        if printf '%s' "$json_line" | grep -qE '^\s*[},]'; then
            if [ -n "$current_sev" ] && [ -n "$current_file" ] && [ -n "$current_line" ]; then
                case "$current_sev" in
                    L1|L2)
                        issue_files+=("$current_file")
                        issue_lines+=("$current_line")
                        issue_sevs+=("$current_sev")
                        ;;
                esac
            fi
            current_file=""
            current_line=""
            current_sev=""
        fi
    done <<< "$json_content"

    [ ${#issue_files[@]} -eq 0 ] && rm -f "$norm_report" && return 1

    # Scan markdown for **Issue #N** headings and match by file+line
    local -A heading_map  # line_num -> issue_num
    local heading_line heading_num
    while IFS= read -r hl; do
        heading_line=$(printf '%s' "$hl" | cut -d: -f1)
        heading_num=$(printf '%s' "$hl" | sed -nE 's/^[0-9]+:\*\*Issue #([0-9]+)\*\*.*/\1/p')
        [ -n "$heading_num" ] && heading_map["$heading_line"]="$heading_num"
    done < <(grep -n '^\*\*Issue #[0-9]\+\*\*' "$norm_report" 2>/dev/null)

    # For each JSON L1/L2 issue, find matching markdown heading by file+line in the issue block
    local idx
    for idx in $(seq 0 $((${#issue_files[@]} - 1))); do
        local jf="${issue_files[$idx]}" jl="${issue_lines[$idx]}" js="${issue_sevs[$idx]}"
        local jsev
        jsev="$(canonicalize_severity "$js")"
        # Find **Issue #N** heading whose block contains file_path and line_range including jl
        for hline in "${!heading_map[@]}"; do
            local block
            block=$(awk -v start="$hline" 'NR < start{next} NR==start{print;inb=1;next} inb && ($0 ~ /^---$/ || $0 ~ /^\*\*Issue #[0-9]+\*\*/ || $0 ~ /^## /){exit} inb{print}' "$norm_report")
            if printf '%s' "$block" | grep -qF "$jf" && printf '%s' "$block" | grep -qF "$jl"; then
                local match_num="${heading_map[$hline]}"
                # Skip if this issue was already bypassed in markdown
                if [ -n "$bypassed_nums" ] && echo "$bypassed_nums" | grep -qw "$match_num"; then
                    break
                fi
                printf '%s\t%s\t%s\n' "$match_num" "$jsev" "$hline"
                break
            fi
        done
    done
    rm -f "$norm_report"
}

extract_blocker_markdown_or_json() {
    local report="$1"
    local markers_tmp
    markers_tmp=$(mktemp) || return 1

    extract_blocker_markers "$report" > "$markers_tmp" 2>/dev/null || true
    if [ ! -s "$markers_tmp" ]; then
        local bypassed_nums=""
        local normalized_tmp=""
        normalized_tmp=$(mktemp) || true
        if [ -n "$normalized_tmp" ]; then
            normalize_report_content "$report" "$normalized_tmp"
            bypassed_nums=$(LC_ALL=C grep -oE '\*\*Issue #[0-9]+\*\* \[.*(非问题|暂不修复)' "$normalized_tmp" \
                | sed -nE 's/\*\*Issue #([0-9]+)\*\*.*/\1/p' | tr '\n' ' ')
            rm -f "$normalized_tmp"
        fi
        infer_severity_from_json "$report" "$bypassed_nums" > "$markers_tmp" 2>/dev/null || true
    fi

    awk -F '\t' 'NF >= 3 { print $1 "\t" $2 "\t" $3 "\tmarkdown" }' "$markers_tmp"
    local rc=$?
    rm -f "$markers_tmp"
    return $rc
}

extract_blocker_candidates() {
    local report="$1"
    local sidecar_tmp

    if sidecar_available "$report"; then
        sidecar_tmp=$(mktemp) || return 1
        if extract_blockers_sidecar "$report" > "$sidecar_tmp" 2>/dev/null; then
            ISSUE_SOURCE_MODE="sidecar"
            cat "$sidecar_tmp"
            rm -f "$sidecar_tmp"
            return 0
        fi
        rm -f "$sidecar_tmp"
    fi

    ISSUE_SOURCE_MODE="markdown"
    extract_blocker_markdown_or_json "$report"
}

extract_issue_block_for_candidate() {
    local report="$1"
    local issue_id="$2"
    local marker_line="$3"
    local source="${4:-markdown}"

    if [ "$source" = "sidecar" ]; then
        extract_issue_block_sidecar "$report" "$issue_id" 2>/dev/null && return 0
    fi

    extract_issue_block "$report" "$marker_line"
}

# 转义 sed REPLACEMENT 元字符 \\ & |(用 | 作 sed 分隔符,无需转义 /)
sed_escape_replacement() {
    printf '%s' "$1" | sed -e 's/[\\&|]/\\&/g'
}

# 在报告里精确替换某 marker 行为 bypass 形式
# 用法: apply_bypass_marker <report> <marker_line> <kind=非问题|暂不修复> <reason>
# 输出:替换后第 marker_line 行的内容(用于测试断言);原文件已被原子写覆盖
apply_bypass_marker() {
    local report="$1"
    local marker_line="$2"
    local kind="$3"
    local reason="$4"
    local severity new_bracket tmp

    # 读出原始 marker 行的括号内容(宽松匹配,兼容 LLM 变体标签)
    # 关键:必须在 ORIGINAL 报告上读取,不能读归一化版本
    # 否则 escaped_raw 会用规范标签(如 [紧急])去匹配原文件的变体标签(如 [阻塞]),替换会失败
    local raw_bracket
    raw_bracket="$(sed -n "${marker_line}p" "$report" \
        | sed -nE 's/.*\[([^]]+).*/\1/p')"
    [ -z "$raw_bracket" ] && return 1

    # 映射到规范 severity(支持 [阻塞]/[Critical: high]/[L1 紧急] 等所有变体)
    severity="$(canonicalize_severity "$raw_bracket")"

    # 构造新括号内容:空原因时形如 [紧急-非问题 ](尾随空格);非空时 [紧急-非问题 误报]
    if [ -z "$reason" ]; then
        new_bracket="[${severity}-${kind} ]"
    else
        new_bracket="[${severity}-${kind} ${reason}]"
    fi

    # 转义 sed REPLACEMENT 元字符(以 | 作分隔符,只需转义 \ & |)
    local escaped_bracket
    escaped_bracket="$(printf '%s' "$new_bracket" | sed -e 's/[\\&|]/\\&/g')"

    # 转义原始括号用于 sed MATCHING 模式
    local escaped_raw
    escaped_raw="$(printf '%s' "[${raw_bracket}]" | sed -e 's/[][\\&|]/\\&/g')"

    # 原子写:替换第 marker_line 行中的原始括号为 bypass 形式
    tmp=$(mktemp "${report}.XXXXXX") || return 1
    if ! sed "${marker_line}s|${escaped_raw}|${escaped_bracket}|" "$report" > "$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    mv -f "$tmp" "$report"
    # 输出新行(便于测试断言)
    sed -n "${marker_line}p" "$report"
}

# 从 TTY(或测试环境 PRE_PUSH_TTY_FIFO)读 1 字节,无回显
# - 测试环境(PRE_PUSH_TTY_FIFO 是普通文件):用 fd 3 持久打开,顺序读字节
# - 真实 TTY:阻塞等待用户按键(/dev/tty 是字符设备,fd 持久)
# 返回:成功时设置全局 KEY;无输入立即返回 1
# Enter 键规范化: \n(0x0A) / \r(0x0D) / 空字节 都被识别为 ""(Enter)
tty_read_byte_nb() {
    if [ -n "${PRE_PUSH_TTY_FIFO:-}" ] && [ -r "$PRE_PUSH_TTY_FIFO" ]; then
        # 测试模式:用 fd 3 持久读
        if [ -z "${TTY_FIFO_FD_OPEN:-}" ]; then
            exec 3< "$PRE_PUSH_TTY_FIFO"
            TTY_FIFO_FD_OPEN=1
        fi
        IFS= read -rsn1 -t 0.5 KEY <&3 2>/dev/null || return 1
    else
        IFS= read -rsn1 KEY < /dev/tty 2>/dev/null || return 1
    fi
    # Enter 规范化
    case "$KEY" in
        $'\n'|$'\r') KEY="" ;;
    esac
}

# 关闭测试模式的 fd
tty_close_test_fd() {
    if [ -n "${TTY_FIFO_FD_OPEN:-}" ]; then
        exec 3<&-
        unset TTY_FIFO_FD_OPEN
    fi
}

# 真实 TTY 模式切换(测试模式 PRE_PUSH_TTY_FIFO 下均为 no-op)
# raw:单键选择(无回显、无行缓冲);cooked:行输入(原生回显 + 行编辑,支持中文/退格/IME)
tty_mode_raw() {
    [ -z "${PRE_PUSH_TTY_FIFO:-}" ] || return 0
    stty raw -echo 2>/dev/null || true
}

tty_mode_cooked() {
    [ -z "${PRE_PUSH_TTY_FIFO:-}" ] || return 0
    if [ -n "${OLD_STTY:-}" ]; then
        stty "$OLD_STTY" 2>/dev/null || true
    else
        stty sane 2>/dev/null || true
    fi
}

# 从 TTY 读一行(用于原因)
# 返回:成功时设置全局 LINE;读失败返回 1
tty_read_line() {
    if [ -n "${PRE_PUSH_TTY_FIFO:-}" ] && [ -r "$PRE_PUSH_TTY_FIFO" ]; then
        IFS= read -r LINE < "$PRE_PUSH_TTY_FIFO" || return 1
    else
        IFS= read -r LINE < /dev/tty || return 1
    fi
}

# 阶段 2 的原因读取:cooked 模式整行读取(原生回显 + 行编辑,修复"原因前台不可见")
# - 真实 TTY:切到 cooked 读一行(终端驱动负责回显中文/退格/IME),再切回 raw
# - 测试模式:从持久 fd 3 顺序读取一行(与单键 choice 共享同一字节流,避免从头重读)
# 返回:0=成功(REASON 已设置)  1=读失败/EOF  2=用户按了 ESC(行首 0x1B,返回重选)
tty_read_reason() {
    local line=""
    if [ -n "${PRE_PUSH_TTY_FIFO:-}" ] && [ -r "$PRE_PUSH_TTY_FIFO" ]; then
        # 测试模式:复用 fd 3,与单键 choice 共享同一字节流
        if [ -z "${TTY_FIFO_FD_OPEN:-}" ]; then
            exec 3< "$PRE_PUSH_TTY_FIFO"
            TTY_FIFO_FD_OPEN=1
        fi
        IFS= read -r line <&3 || return 1
    else
        # 真实 TTY:cooked 模式让终端驱动负责回显与行编辑
        tty_mode_cooked
        if ! IFS= read -r line < /dev/tty; then
            tty_mode_raw
            return 1
        fi
        tty_mode_raw
    fi
    # 行首 ESC(0x1B)→ 返回重选
    case "$line" in
        $'\x1b'*) REASON=""; return 2 ;;
    esac
    REASON="$line"
    return 0
}

# 打印一行到 TTY
tty_print() {
    if [ -n "${PRE_PUSH_TTY_FIFO_OUT:-}" ] && [ -w "$PRE_PUSH_TTY_FIFO_OUT" ]; then
        printf '%s\n' "$1" > "$PRE_PUSH_TTY_FIFO_OUT" 2>/dev/null
    elif [ -t 1 ]; then
        printf '%s\n' "$1" > /dev/tty 2>/dev/null
    else
        printf '%s\n' "$1" >&2
    fi
}

# 打印字符串(无换行)
tty_print_n() {
    if [ -n "${PRE_PUSH_TTY_FIFO_OUT:-}" ] && [ -w "$PRE_PUSH_TTY_FIFO_OUT" ]; then
        printf '%s' "$1" > "$PRE_PUSH_TTY_FIFO_OUT" 2>/dev/null
    elif [ -t 1 ]; then
        printf '%s' "$1" > /dev/tty 2>/dev/null
    else
        printf '%s' "$1" >&2
    fi
}

# 交互式 bypass 主循环
# 返回码: 0=全部 bypass 成功,可放行  1=TTY 不可用 / 有 issue 选 是问题  2=用户按 q 取消
interactive_bypass_loop() {
    local report="$1"
    local OLD_STTY=""

    # TTY 不可用(且无测试 FIFO)→ 返回 1,走硬阻断
    # 检查 stdout 是 TTY(因为 stdin 被 git 占了)。在 CI / 管道环境里 stdout 不是 TTY。
    if [ -z "${PRE_PUSH_TTY_FIFO:-}" ] && [ ! -t 1 ]; then
        return 1
    fi

    # 真实 TTY 模式:切到 raw 支持单键选择(原因阶段临时切 cooked),退出时恢复
    if [ -z "${PRE_PUSH_TTY_FIFO:-}" ]; then
        OLD_STTY=$(stty -g 2>/dev/null) || OLD_STTY=""
        trap 'stty "$OLD_STTY" 2>/dev/null || true' RETURN
        tty_mode_raw
    else
        # 测试模式:确保 fd 在退出时关闭
        trap 'tty_close_test_fd' RETURN
    fi

    # 提取所有未 bypass 的 issue。优先使用 CodeReview sidecar，旧报告回退到 Markdown marker。
    extract_blocker_candidates "$report" > "$BYPASS_TMP" || return 1
    [ -s "$BYPASS_TMP" ] || return 0   # 没有任何阻断 issue,直接放行

    local total idx=0 blocked=0
    total=$(wc -l < "$BYPASS_TMP" | tr -d ' ')

    while IFS=$'\t' read -r ISSUE_NUM SEVERITY MARKER_LINE ISSUE_SOURCE; do
        idx=$((idx + 1))
        local processed=0
        [ -n "${ISSUE_SOURCE:-}" ] || ISSUE_SOURCE="markdown"

        while [ "$processed" -eq 0 ]; do
            # 阶段 1: 三选一(raw 模式单键,1/2/3 直接选定,无需空格循环)
            local choice=""
            while [ -z "$choice" ]; do
                tty_print "============================================================"
                tty_print "[CX-AICODE] 阻断级问题 #${idx}/${total}"
                tty_print "============================================================"
                # 打印 issue 块(用 tty_print 避免 sub-shell 闭包)
                local block
                block="$(extract_issue_block_for_candidate "$report" "$ISSUE_NUM" "$MARKER_LINE" "$ISSUE_SOURCE")"
                local IFS=$'\n'
                for line in $block; do
                    tty_print "  $line"
                done
                unset IFS
                tty_print "============================================================"
                tty_print "  请选择处置方式:"
                tty_print "    [1] 是问题      (将阻断 push)"
                tty_print "    [2] 非问题      (误报, 原因可空)"
                tty_print "    [3] 暂不修复    (原因必填)"
                tty_print "    [q] 取消整个 push"
                tty_print_n "> "

                tty_read_byte_nb || return 1
                case "$KEY" in
                    1) choice="is-problem" ;;
                    2) choice="non-issue" ;;
                    3) choice="wont-fix"  ;;
                    q|Q) return 2 ;;
                    *) choice="" ;;   # 非法键,重新显示菜单
                esac
                # 回显选定的键,让用户确认输入已落入
                [ -n "$choice" ] && { tty_print_n "$KEY"; tty_print ""; }
            done

            # 阶段 2: 原因填写(仅 非问题/暂不修复);cooked 模式原生回显 + 行编辑
            case "$choice" in
                non-issue)
                    tty_print_n "  原因(可空, 按 Esc+回车 返回重选): "
                    tty_read_reason
                    local rc=$?
                    if [ $rc -eq 2 ]; then
                        continue   # ESC 回退 → 外层 while(processed) 顶部,choice 重置,菜单重显
                    elif [ $rc -ne 0 ]; then
                        return 1
                    fi
                    if ! record_bypass_decision "$report" "$ISSUE_NUM" "$SEVERITY" "非问题" "$REASON"; then
                        return 1
                    fi
                    if [ "$ISSUE_SOURCE" != "sidecar" ] && [ "${MARKER_LINE:-0}" -gt 0 ] \
                        && ! apply_bypass_marker "$report" "$MARKER_LINE" "非问题" "$REASON" > /dev/null; then
                        return 1
                    fi
                    tty_print "  → [${SEVERITY}-非问题 ${REASON:+$REASON}]"
                    processed=1
                    ;;
                wont-fix)
                    while :; do
                        tty_print_n "  原因(必填, 按 Esc+回车 返回重选): "
                        tty_read_reason
                        local rc=$?
                        if [ $rc -eq 2 ]; then
                            continue 2   # ESC 回退 → 外层 while(processed) 顶部,菜单重显
                        elif [ $rc -ne 0 ]; then
                            return 1
                        fi
                        if [ -z "$REASON" ]; then
                            tty_print "  错误:暂不修复 必须填写原因。"
                            continue
                        fi
                        break
                    done
                    if ! record_bypass_decision "$report" "$ISSUE_NUM" "$SEVERITY" "暂不修复" "$REASON"; then
                        return 1
                    fi
                    if [ "$ISSUE_SOURCE" != "sidecar" ] && [ "${MARKER_LINE:-0}" -gt 0 ] \
                        && ! apply_bypass_marker "$report" "$MARKER_LINE" "暂不修复" "$REASON" > /dev/null; then
                        return 1
                    fi
                    tty_print "  → [${SEVERITY}-暂不修复 $REASON]"
                    processed=1
                    ;;
                is-problem)
                    blocked=1
                    tty_print "  → 已选择 是问题,本 issue 将阻断 push。"
                    processed=1
                    ;;
            esac
        done
    done < "$BYPASS_TMP"

    [ "$blocked" -eq 0 ]
}

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" \
    || fail "当前目录不是有效的 Git 仓库。"

cd "$REPO_ROOT" \
    || fail "无法进入项目根目录：$REPO_ROOT"

UPLOAD_NODE_BIN="$(find_node_bin)"
HOOK_PLUGIN_ROOT="$(resolve_hook_plugin_root)"
UPLOAD_SCRIPT_ROOT="${HOOK_PLUGIN_ROOT:-$REPO_ROOT}"
SIDECAR_NODE_BIN="$UPLOAD_NODE_BIN"
SIDECAR_HELPER="${HOOK_PLUGIN_ROOT:-$REPO_ROOT}/scripts/codereview/sidecar-cli.js"

HEAD_OID="$(git rev-parse HEAD 2>/dev/null)" \
    || fail "无法获取当前分支的 HEAD。"

NEED_CHECK=0
LAST_LOCAL_REF=""
LAST_LOCAL_OID=""
LAST_REMOTE_OID=""
LAST_REMOTE_NAME=""
LAST_IS_FIRST_PUSH=0

# pre-push 会从标准输入传入：
# <local-ref> <local-object-name> <remote-ref> <remote-object-name>
while read -r LOCAL_REF LOCAL_OID REMOTE_REF REMOTE_OID
do
    [ -z "${LOCAL_REF:-}" ] && continue

    # 记录最后一次成功 read 的 ref 信息(供上传 spawn 与过期检测使用)
    LAST_LOCAL_REF="$LOCAL_REF"
    LAST_LOCAL_OID="$LOCAL_OID"
    LAST_REMOTE_OID="$REMOTE_OID"
    LAST_REMOTE_NAME="${1:-}"

    # 删除远端 ref 时，本地 object ID 为全零值，不涉及代码新增或修改。
    if is_zero_oid "$LOCAL_OID" || [ "$LOCAL_REF" = "(delete)" ]; then
        continue
    fi

    # 第一版仅检查远端分支更新，暂时跳过 tag 等其他 ref。
    case "$REMOTE_REF" in
        refs/heads/*)
            NEED_CHECK=1
            ;;
        *)
            continue
            ;;
    esac

    # 提交时间从 git 历史取，理论上不依赖工作区；但当前版本仍保守地只允许 push 当前已检出的分支。
    if [ "$LOCAL_OID" != "$HEAD_OID" ]; then
        fail "当前简单版只支持 push 当前已检出的分支。

检测到待推送分支并非当前 HEAD：
  本地 ref：$LOCAL_REF
  远端 ref：$REMOTE_REF

请切换到对应分支后单独执行 git push。"
    fi

    if is_zero_oid "$REMOTE_OID"; then
        # 首次推送远端新分支：保守检查该分支当前包含的全部文件。
        LAST_IS_FIRST_PUSH=1
        git ls-tree -r --name-only -z "$LOCAL_OID" >> "$TMP_FILES" \
            || fail "无法读取首次推送分支的文件列表：$LOCAL_REF"
    else
        # 普通 push：直接比较远端 commit 与本地 commit 的最终差异文件。
        # 提交时间对删除/重命名文件同样有效，故删除文件也参与过期比较。
        git diff \
            --name-only \
            -z \
            --diff-filter=ACMRT \
            "$REMOTE_OID" \
            "$LOCAL_OID" \
            -- \
            >> "$TMP_FILES" \
            || fail "无法读取本次 push 涉及的文件列表：$LOCAL_REF"
    fi
done

# 删除分支或仅推送 tag 时无需执行 CodeReview 门禁。
[ "$NEED_CHECK" -eq 0 ] && exit 0

UPLOAD_PUSH_ID="psh_$(uuidgen 2>/dev/null \
    || cat /proc/sys/kernel/random/uuid 2>/dev/null \
    || node -e 'console.log(require("crypto").randomUUID())' 2>/dev/null \
    || echo "$$-$(date +%s)")"
UPLOAD_COMMIT="${LAST_LOCAL_OID:-}"
UPLOAD_BRANCH="${LAST_LOCAL_REF:-}"
UPLOAD_REMOTE="${LAST_REMOTE_NAME:-}"

# 过期检测用的提交范围：普通 push 取远端..本地，首次推送取本地分支全历史。
if [ "${LAST_IS_FIRST_PUSH:-0}" = "1" ] || is_zero_oid "${LAST_REMOTE_OID:-}"; then
    PUSH_RANGE="${LAST_LOCAL_OID:-HEAD}"
else
    PUSH_RANGE="${LAST_REMOTE_OID}..${LAST_LOCAL_OID}"
fi

# 查找最新报告。yyyyMMdd-HHmmss 格式可以直接按文件名排序。
#
# P2 报告选取收敛：候选 = 全局报告(.cx/reports/codereview/) + 当前 focusedSpec 的报告。
# 排除其它 spec 的报告，避免"更新但与本次 push 代码无关的报告"拉高 REPORT_MTIME、
# 掩盖本次 push 代码的真实过期。无 focusedSpec 或候选为空时回退到扫全部 spec（旧行为）。
FOCUSED_SPEC="$(read_focused_spec)"

shopt -s nullglob
REPORT_FILES=()
# 全局报告恒为候选（全量审查覆盖一切）
for _f in "$REPORT_DIR"/$REPORT_PATTERN; do
    REPORT_FILES+=("$_f")
done
# focusedSpec 的报告为候选；排除其它 spec（与 diagnose.js findLatestReport 同款位置约定）
if [ -n "$FOCUSED_SPEC" ]; then
    for _f in ".cx/$FOCUSED_SPEC"/reports/codereview/$REPORT_PATTERN; do
        REPORT_FILES+=("$_f")
    done
fi
# 兜底：无 focusedSpec（未跑过 cx-work）或候选为空 → 扫全部 spec，避免"找不到报告"误阻断
if [ "${#REPORT_FILES[@]}" -eq 0 ]; then
    for _f in "$REPORT_DIR"/$REPORT_PATTERN .cx/*/reports/codereview/$REPORT_PATTERN; do
        REPORT_FILES+=("$_f")
    done
fi
shopt -u nullglob

if [ "${#REPORT_FILES[@]}" -eq 0 ]; then
    fail "未找到有效的 CodeReview 报告。

请先执行：
  /cx-codereview

预期报告路径：
  .cx/{SPEC-ID}/reports/codereview/CodeReview-yyyyMMdd-HHmmss.md（spec scope）
  或 .cx/reports/codereview/CodeReview-yyyyMMdd-HHmmss.md（全量审查）"
fi

# 按 basename(时间戳)取最新，避免跨全局/per-spec 目录时路径前缀淹没时间戳
LATEST_REPORT="$(printf '%s\n' "${REPORT_FILES[@]}" | awk -F/ '{print $NF"\t"$0}' | LC_ALL=C sort | tail -n 1 | cut -f2-)"

if [ ! -f "$LATEST_REPORT" ]; then
    fail "最新 CodeReview 报告不是有效文件：$LATEST_REPORT"
fi

# ============================================================
# 新鲜度门禁（必须先于内容审查）：报告必须覆盖本次 push 的最新代码。
# 报告过期时其内容（无论"有问题/无问题"）对新代码都无意义 → 立即失败，
# 提示先重新生成报告、分析代码、制定修改计划，而不进入 bypass 流程。
# ============================================================
REPORT_MTIME="$(get_report_epoch "$LATEST_REPORT")"

# -z 与 read -d '' 配合使用，可正确处理包含空格的文件路径。
while IFS= read -r -d '' FILE_PATH
do
    [ -z "$FILE_PATH" ] && continue

    # 排除 CodeReview 报告目录自身，避免循环检查。
    case "$FILE_PATH" in
        .cx/reports/*)
            continue
            ;;
    esac

    # 取该文件在本次推送范围内的最新提交时间（committer epoch）。
    # 提交时间从 git 历史取，不依赖工作区：删除/重命名文件、GBK 文件名均可正确解析。
    FILE_CT="$(get_file_commit_epoch "$FILE_PATH" "$PUSH_RANGE")"
    # git log 无记录（异常情况）时跳过，既不误伤也不静默放行。
    [ -n "$FILE_CT" ] || continue

    # 报告必须严格晚于代码的提交时间；提交时间不早于报告时间即判定过期。
    if [ "$FILE_CT" -ge "$REPORT_MTIME" ]; then
        printf '  - %q\n' "$FILE_PATH" >> "$STALE_FILES_TMP"
    fi
done < "$TMP_FILES"

if [ -s "$STALE_FILES_TMP" ]; then
    print_separator
    echo "[CX-AICODE] Git push 已阻止：代码已变更，但 CodeReview 报告未覆盖最新代码。" >&2
    echo "" >&2
    echo "报告文件：" >&2
    echo "  $LATEST_REPORT" >&2
    echo "" >&2
    echo "以下文件的提交时间不早于报告生成时间（报告未覆盖最新代码）：" >&2
    cat "$STALE_FILES_TMP" >&2
    echo "" >&2
    echo "请按以下顺序处理后再 push：" >&2
    echo "  1. 执行 /cx-codereview 重新分析最新代码并生成报告" >&2
    echo "  2. 若新报告含 [紧急]/[严重] 问题，制定修改计划并修复（或按既定流程 bypass）" >&2
    echo "  3. 报告刷新后再 push" >&2
    print_separator
    exit 1
fi

# 提取未 bypass 的 issue。sidecar 存在时用结构化 JSON；旧报告回退到 Markdown marker / cx-agent-result。
if extract_blocker_candidates "$LATEST_REPORT" > "$ISSUES_TMP"; then
    if [ -s "$ISSUES_TMP" ]; then
        # 有真实阻断级问题:尝试交互式 bypass
        bypass_rc=0
        interactive_bypass_loop "$LATEST_REPORT" || bypass_rc=$?

        case $bypass_rc in
            0)
                # 所有 issue 已 bypass;重新检查(理论应为空)
                if extract_blocker_candidates "$LATEST_REPORT" > "$ISSUES_TMP" \
                    && [ -s "$ISSUES_TMP" ]; then
                    fail "交互处理后仍有未 bypass 的阻断级问题。"
                fi
                ;;
            1)
                # TTY 不可用 / 系统错误 / 有 issue 选 是问题 → 走原有硬阻断
                print_separator
                echo "[CX-AICODE] Git push 已阻止：CodeReview 报告包含阻断级问题。" >&2
                echo "" >&2
                echo "报告文件：" >&2
                echo "  $LATEST_REPORT" >&2
                echo "" >&2
                echo "命中内容（未 bypass）:" >&2
                if [ "${ISSUE_SOURCE_MODE:-markdown}" = "sidecar" ]; then
                    while IFS=$'\t' read -r ISSUE_NUM SEVERITY _ ISSUE_SOURCE; do
                        [ -n "${ISSUE_SOURCE:-}" ] || ISSUE_SOURCE="sidecar"
                        printf '  - %s [%s] (%s)\n' "$ISSUE_NUM" "$SEVERITY" "$ISSUE_SOURCE" >&2
                    done < "$ISSUES_TMP"
                else
                    # 重新提取纯文本 marker 行给用户看
                    LC_ALL=C grep -nE "$BLOCKER_MARKER_RE" "$LATEST_REPORT" \
                        | LC_ALL=C grep -vE "$BYPASSED_MARKER_RE" \
                        | sed 's/^/  /' >&2
                fi
                echo "" >&2
                echo "请解决 [紧急] 和 [严重] 问题后，重新执行 /cx-codereview。" >&2
                echo "如确认问题为误报或暂不修复，请编辑报告将" >&2
                echo "[紧急] 改为 [紧急-非问题 <原因>] 或 [紧急-暂不修复 <原因>]。" >&2
                print_separator
                exit 1
                ;;
            2)
                # 用户主动按 q 取消
                print_separator
                echo "[CX-AICODE] Git push 已阻止:用户取消 bypass 流程。" >&2
                echo "" >&2
                echo "报告未修改。下次 push 时如需继续处理,可重跑 /cx-codereview 后再试," >&2
                echo "或在交互中按 2 / 3 将问题标记为 非问题/暂不修复。" >&2
                print_separator
                exit 1
                ;;
            *)
                fail "交互流程异常退出 (rc=${bypass_rc})。"
                ;;
        esac
    fi
fi

print_separator
echo "[CX-AICODE] CodeReview 门禁检查通过。" >&2
echo "报告文件：" >&2
echo "  $LATEST_REPORT" >&2
print_separator

# ============================================================
# CodeReview Push 上传（fire-and-forget）
#
# 触发条件:mtime 检查通过 + LATEST_REPORT 存在
# 行为:spawn node 把 push summary + bypass 事件异步上传到中央 DB
# 失败降级:Node 缺失 / upload-push.js 缺失 / spawn 失败 → 仅写 warn 日志,不阻断 push
# 关键约束:
#   - 必须等 mtime 通过才 spawn(否则 DB 会记录未通过 push)
#   - 跨平台(Git Bash for Windows 不支持 setsid):用 nohup + & + disown
#   - 子进程 cwd 不可靠:显式 cd + 传 --project-root
#   - pre-push 退出不受 spawn 影响
# ============================================================
UPLOAD_ERROR_LOG="$REPO_ROOT/.cx/usage/codereview-upload-errors.log"
mkdir -p "$(dirname "$UPLOAD_ERROR_LOG")" 2>/dev/null || true

if [ -n "$UPLOAD_NODE_BIN" ] && [ -f "$UPLOAD_SCRIPT_ROOT/scripts/codereview/upload-push.js" ]; then
    (
        cd "$REPO_ROOT" || exit 0
        nohup "$UPLOAD_NODE_BIN" "$UPLOAD_SCRIPT_ROOT/scripts/codereview/upload-push.js" \
            --push-id "$UPLOAD_PUSH_ID" \
            --report "$LATEST_REPORT" \
            --commit "$UPLOAD_COMMIT" \
            --branch "$UPLOAD_BRANCH" \
            --remote "$UPLOAD_REMOTE" \
            --project-root "$REPO_ROOT" \
            </dev/null >/dev/null 2>>"$UPLOAD_ERROR_LOG" &
        disown 2>/dev/null || true
    )
else
    printf '[%s] codereview upload skipped: node=%s upload-script=%s\n' \
        "$(date -Iseconds)" \
        "${UPLOAD_NODE_BIN:-missing}" \
        "$([ -f "$UPLOAD_SCRIPT_ROOT/scripts/codereview/upload-push.js" ] && echo present || echo missing)" \
        >> "$UPLOAD_ERROR_LOG"
fi

exit 0
