@startuml 模块流程图

skinparam activity {
    BackgroundColor LightBlue
    BorderColor Black
    FontSize 12
    ArrowColor Black
}

skinparam note {
    BackgroundColor LightYellow
    BorderColor Black
}

title 系统核心模块业务流程图

|用户|
start

:访问系统;

|#LightGreen|认证模块|
if (是否已登录?) then (否)
    :跳转登录页面;

    if (是否有账号?) then (否)
        :填写注册信息;
        :提交注册请求;

        |#LightCoral|验证模块|
        :验证邮箱/手机号格式;
        :验证密码强度;
        :检查用户名是否重复;

        if (验证通过?) then (是)
            |#LightGreen|认证模块|
            :发送验证码;
            :用户输入验证码;

            if (验证码正确?) then (是)
                :创建用户账号;
                :加密存储密码;
                :生成 JWT Token;
                :返回注册成功;
                note right
                    注册成功后
                    自动登录
                end note
            else (否)
                :返回验证码错误;
                stop
            endif
        else (否)
            :返回验证失败信息;
            stop
        endif
    else (是)
        :输入用户名和密码;
        :提交登录请求;

        |#LightCoral|验证模块|
        :验证用户名格式;
        :验证密码格式;

        if (格式验证通过?) then (是)
            |#LightGreen|认证模块|
            :查询用户信息;

            if (用户存在?) then (是)
                :验证密码;

                if (密码正确?) then (是)
                    :生成 JWT Token;
                    :记录登录日志;
                    :返回 Token 和用户信息;
                    note right
                        Token 包含：
                        - 用户 ID
                        - 角色信息
                        - 过期时间
                    end note
                else (否)
                    :返回密码错误;
                    :记录失败日志;
                    stop
                endif
            else (否)
                :返回用户不存在;
                stop
            endif
        else (否)
            :返回格式错误;
            stop
        endif
    endif
else (是)
    :验证 Token 有效性;

    if (Token 有效?) then (否)
        :清除本地 Token;
        :跳转登录页面;
        stop
    else (是)
        :继续访问;
    endif
endif

|#LightBlue|权限模块|
:解析 Token 获取用户信息;
:获取用户角色;
:获取角色权限列表;

if (访问需要权限?) then (是)
    :检查用户权限;

    if (有访问权限?) then (否)
        :返回权限不足;
        :记录访问日志;
        stop
    else (是)
        :允许访问;
        note right
            权限验证通过
            记录访问日志
        end note
    endif
else (否)
    :允许访问;
endif

|#LightSalmon|业务模块|
partition "业务数据操作流程" {

    if (操作类型?) then (查询)
        :接收查询参数;

        |#LightCoral|验证模块|
        :验证查询参数;

        if (参数有效?) then (是)
            |#LightSalmon|业务模块|
            :构建查询条件;
            :检查缓存;

            if (缓存命中?) then (是)
                :返回缓存数据;
            else (否)
                :查询数据库;
                :格式化数据;
                :写入缓存;
                :返回查询结果;
            endif

            :记录查询日志;
        else (否)
            :返回参数错误;
            stop
        endif

    elseif (录入) then
        :接收业务数据;

        |#LightCoral|验证模块|
        :验证必填字段;
        :验证数据格式;
        :验证业务规则;

        if (验证通过?) then (是)
            |#LightSalmon|业务模块|
            :开启数据库事务;

            :插入业务数据;
            :更新关联数据;

            if (操作成功?) then (是)
                :提交事务;
                :清除相关缓存;
                :记录操作日志;
                :返回成功信息;
            else (否)
                :回滚事务;
                :返回失败信息;
                :记录错误日志;
                stop
            endif
        else (否)
            :返回验证失败;
            stop
        endif

    elseif (更新) then
        :接收更新数据;

        |#LightCoral|验证模块|
        :验证数据 ID;
        :验证更新字段;
        :验证业务规则;

        if (验证通过?) then (是)
            |#LightSalmon|业务模块|
            :查询原始数据;

            if (数据存在?) then (是)
                :开启数据库事务;
                :更新业务数据;
                :更新关联数据;

                if (操作成功?) then (是)
                    :提交事务;
                    :清除相关缓存;
                    :记录操作日志;
                    :返回成功信息;
                else (否)
                    :回滚事务;
                    :返回失败信息;
                    :记录错误日志;
                    stop
                endif
            else (否)
                :返回数据不存在;
                stop
            endif
        else (否)
            :返回验证失败;
            stop
        endif

    elseif (删除) then
        :接收删除请求;

        |#LightCoral|验证模块|
        :验证数据 ID;
        :检查删除权限;

        if (验证通过?) then (是)
            |#LightSalmon|业务模块|
            :查询数据;

            if (数据存在?) then (是)
                :检查关联数据;

                if (可以删除?) then (是)
                    :开启数据库事务;
                    :软删除/硬删除数据;
                    :处理关联数据;

                    if (操作成功?) then (是)
                        :提交事务;
                        :清除相关缓存;
                        :记录操作日志;
                        :返回成功信息;
                    else (否)
                        :回滚事务;
                        :返回失败信息;
                        :记录错误日志;
                        stop
                    endif
                else (否)
                    :返回无法删除提示;
                    note right
                        存在关联数据
                        不允许删除
                    end note
                    stop
                endif
            else (否)
                :返回数据不存在;
                stop
            endif
        else (否)
            :返回验证失败;
            stop
        endif

    else (分析)
        :接收分析请求;

        |#LightCoral|验证模块|
        :验证分析参数;
        :验证时间范围;

        if (参数有效?) then (是)
            |#LightSalmon|业务模块|
            :检查分析缓存;

            if (缓存有效?) then (是)
                :返回缓存结果;
            else (否)
                :执行数据统计;
                :计算分析指标;
                :生成图表数据;
                :缓存分析结果;
                :返回分析报告;
            endif

            :记录分析日志;
        else (否)
            :返回参数错误;
            stop
        endif
    endif
}

|#LightGray|日志模块|
:记录完整操作日志;
:更新统计数据;

|用户|
:接收响应结果;
:展示数据/提示信息;

stop

note right of "认证模块"
    认证模块负责：
    - 用户注册
    - 用户登录
    - Token 生成和验证
    - 会话管理
end note

note right of "权限模块"
    权限模块负责：
    - 角色管理
    - 权限分配
    - 访问控制
    - 权限验证
end note

note right of "业务模块"
    业务模块负责：
    - 数据 CRUD 操作
    - 业务规则执行
    - 数据统计分析
    - 缓存管理
end note

note right of "验证模块"
    验证模块负责：
    - 参数格式验证
    - 业务规则验证
    - 数据完整性验证
    - 安全性验证
end note

@enduml
